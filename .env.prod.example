# Production environment for docker-compose.prod.yml. Copy to .env.prod on the
# VPS, fill in real values, and keep it out of version control (chmod 600).
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.prod up -d --build

# --- Postgres (job store) ---------------------------------------------------
POSTGRES_USER=dfl24
# Embedded in the DFL24_DATABASE_URL connection string, so keep it URL-safe:
# use only [A-Za-z0-9._~-] (no @ : / # ? &) or the URL will misparse.
POSTGRES_PASSWORD=CHANGE_ME_long_random_secret
POSTGRES_DB=dfl24sim

# --- MinIO (artifact storage) -----------------------------------------------
MINIO_ROOT_USER=dfl24
# Embedded in the MC_HOST_store URL for backups, so keep it URL-safe too:
# only [A-Za-z0-9._~-] (no @ : / # ? &).
MINIO_ROOT_PASSWORD=CHANGE_ME_long_random_secret
MINIO_BUCKET=dfl24-artifacts
# Public HTTPS base that presigned artifact URLs carry; host must equal S3_HOSTNAME.
MINIO_PUBLIC_URL=https://artifacts.example.com

# --- Public hostnames (Caddy TLS) -------------------------------------------
# DNS A/AAAA records for both must point at this VPS before first `up`.
MCP_HOSTNAME=mcp.example.com
S3_HOSTNAME=artifacts.example.com
# The MCP endpoint's public URL; OAuth resource metadata is published here.
SERVER_BASE_URL=https://mcp.example.com

# --- WorkOS AuthKit (production OAuth) --------------------------------------
# Empty disables auth — never leave empty in production.
AUTHKIT_DOMAIN=https://your-app.authkit.app

# --- Worker resource limits -------------------------------------------------
# Leave the box roughly one core for Postgres + API; set to about (cores - 1).
WORKER_CPUS=3
WORKER_MEMORY=6g

# --- Backups ----------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=14
