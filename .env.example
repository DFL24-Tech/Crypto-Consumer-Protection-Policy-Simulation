# Copy to .env to override the compose dev defaults.
POSTGRES_USER=dfl24
POSTGRES_PASSWORD=dfl24
POSTGRES_DB=dfl24sim
POSTGRES_PORT=5432
MINIO_ROOT_USER=dfl24
MINIO_ROOT_PASSWORD=dfl24secret
MINIO_BUCKET=dfl24-artifacts
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# host-reachable base URL that signed artifact links carry
MINIO_PUBLIC_URL=http://localhost:9000
# WorkOS AuthKit (leave AUTHKIT_DOMAIN empty for no-auth local dev;
# see server/dfl24sim_server/auth.py)
AUTHKIT_DOMAIN=
SERVER_BASE_URL=http://localhost:8000
# WorkOS AuthKit hosted login for the web/ app (same AuthKit project as
# AUTHKIT_DOMAIN above — see web/README.md for setup steps)
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
# Changing this requires rebuilding the web image (docker compose up -d --build web), not just restarting it -- see web/Dockerfile.
WEB_REDIRECT_URI=http://localhost:3000/callback
